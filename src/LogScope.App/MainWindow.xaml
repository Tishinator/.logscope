<Window x:Class="LogScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogScope.App.ViewModels"
        xmlns:views="clr-namespace:LogScope.App.Views"
        xmlns:conv="clr-namespace:LogScope.App.Converters"
        Title=".logscope" Height="700" Width="1150"
        Icon="Assets/app.ico"
        Background="#252526">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <HierarchicalDataTemplate DataType="{x:Type vm:WorkspaceNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="OnNodeClicked"
                        ToolTip="{Binding Tooltip}" Background="Transparent"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <TextBlock Text="📄" Visibility="{Binding IsFile, Converter={StaticResource BoolToVis}}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#DDD"/>
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open"
                                  Command="{Binding PlacementTarget.Tag.OpenInNewTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open in new tab"
                                  Command="{Binding PlacementTarget.Tag.OpenInNewTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Reveal in Explorer"
                                  Command="{Binding PlacementTarget.Tag.RevealInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open in default editor"
                                  Command="{Binding PlacementTarget.Tag.OpenInEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ===== Branded header bar ===== -->
        <Border DockPanel.Dock="Top" Padding="12,7">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1B2B3F" Offset="0"/>
                    <GradientStop Color="#22344C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <!-- Right-aligned menu -->
                <Menu DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center">
                    <Menu.Resources>
                        <!-- Child (dropdown) items render on the light system popup -->
                        <Style x:Key="DropItem" TargetType="MenuItem">
                            <Setter Property="Foreground" Value="#1B2B3F"/>
                        </Style>
                    </Menu.Resources>
                    <MenuItem Header="_Open" Foreground="#E6ECF2">
                        <MenuItem Header="Open File…" Command="{Binding OpenFileCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="Open Folder…" Command="{Binding OpenFolderCommand}" Style="{StaticResource DropItem}"/>
                    </MenuItem>
                    <MenuItem Header="_Profiles" Foreground="#E6ECF2">
                        <MenuItem Header="New parser profile… (for current file)" Command="{Binding NewProfileCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="Edit parser for current tab…" Command="{Binding EditParserCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="Import profile…" Command="{Binding ImportProfileCommand}" Style="{StaticResource DropItem}"/>
                    </MenuItem>
                    <MenuItem Header="_View" Foreground="#E6ECF2">
                        <MenuItem Header="Split all open logs side-by-side"
                                  Command="{Binding ToggleCompareCommand}" IsEnabled="{Binding CanCompare}"
                                  Style="{StaticResource DropItem}"
                                  ToolTip="Or right-click a tab → Split with active tab"/>
                    </MenuItem>
                    <MenuItem Header="_Settings" Foreground="#E6ECF2">
                        <MenuItem Header="Color rules…" Command="{Binding EditColorRulesCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="Flag rules…" Command="{Binding EditFlagRulesCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="File extensions…" Command="{Binding EditExtensionsCommand}" Style="{StaticResource DropItem}"/>
                        <MenuItem Header="Reset settings…" Command="{Binding ResetSettingsCommand}" Style="{StaticResource DropItem}"/>
                    </MenuItem>
                </Menu>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo-full.png" Height="34" Margin="0,0,2,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Border Background="#14B8A6" CornerRadius="3" Padding="5,1" Margin="14,2,0,0" VerticalAlignment="Center">
                        <TextBlock Text="read-only" Foreground="#0C2A26" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="offline log analysis" Foreground="#7C99B8" FontSize="11"
                               VerticalAlignment="Center" Margin="10,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
        <!-- ===== Landing screen (no workspace) ===== -->
        <Grid Visibility="{Binding HasWorkspace, Converter={StaticResource InverseBoolToVis}}"
              x:Name="LandingPanel">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="Assets/logo-full.png" Width="460" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,22"/>
                <TextBlock Text="Read-only log analysis for SDETs — offline and safe."
                           FontSize="14" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,28"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Open File…" Command="{Binding OpenFileCommand}"
                            Padding="20,10" Margin="0,0,12,0" FontSize="14"/>
                    <Button Content="Open Folder…" Command="{Binding OpenFolderCommand}"
                            Padding="20,10" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ===== Workspace view ===== -->
        <Grid Visibility="{Binding HasWorkspace, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="WorkspaceColumn" Width="260" MinWidth="26"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: workspace tree (collapsible accordion-style) -->
            <DockPanel Grid.Column="0" Background="#252526">
                <Border DockPanel.Dock="Top" Background="#333" Padding="4,6">
                    <DockPanel>
                        <Button x:Name="WorkspaceToggle" DockPanel.Dock="Left" Content="◀" Click="OnToggleWorkspace"
                                Width="20" Padding="0" Margin="0,0,4,0" FontSize="11" BorderThickness="0"
                                Background="Transparent" Foreground="#CCC" ToolTip="Collapse / expand the workspace panel"/>
                        <StackPanel x:Name="WorkspaceHeaderDetails" Orientation="Horizontal">
                            <TextBlock Text="WORKSPACE" Foreground="#999" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                                <Button Content="File" Command="{Binding OpenFileCommand}" Padding="6,1" Margin="0,0,4,0" FontSize="11"/>
                                <Button Content="Folder" Command="{Binding OpenFolderCommand}" Padding="6,1" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <TreeView x:Name="Tree" ItemsSource="{Binding WorkspaceRoots}"
                          Background="#252526" BorderThickness="0" Foreground="#DDD">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>

            <GridSplitter x:Name="WorkspaceSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#1A1A1A"/>

            <!-- Right: persistent tab strip + content (single tab OR split group) -->
            <DockPanel Grid.Column="2">

                <!-- ===== Tab strip (always visible; right-click to split) ===== -->
                <ListBox DockPanel.Dock="Top" x:Name="TabStrip" ItemsSource="{Binding OpenTabs}"
                         SelectedItem="{Binding SelectedTab}" Background="#2A2A2A" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Tab" Background="#2A2A2A" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0" Padding="10,5">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Tab" Property="Background" Value="#1E1E1E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Split with active tab"
                                                  Command="{Binding PlacementTarget.Tag.SplitWithActiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Remove from split"
                                                  Command="{Binding PlacementTarget.Tag.RemoveFromSplitCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" Foreground="#DDD" VerticalAlignment="Center"/>
                                <Border Background="#C0392B" CornerRadius="7" Padding="5,0" Margin="6,0,0,0"
                                        VerticalAlignment="Center" MinWidth="16" ToolTip="Flagged events">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FlaggedCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding FlaggedCount}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                </Border>
                                <Button Content="✕" Click="OnCloseTab" Tag="{Binding}" Margin="8,0,0,0"
                                        Padding="3,0" BorderThickness="0" Background="Transparent" Foreground="#999"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ===== Split-view sync bar (only in split) ===== -->
                <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8,5"
                        Visibility="{Binding CompareMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Split view" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Sync:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="120" VerticalAlignment="Center" ItemsSource="{Binding SyncModes}"
                                  SelectedItem="{Binding SyncMode}" Margin="0,0,12,0"/>
                        <TextBlock Text="Right-click another tab to add it. Pick Line/Timestamp, then select a row to align panes flagged 'Sync'."
                                   Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Exit split" Command="{Binding ExitCompareCommand}" Padding="8,2"/>
                    </StackPanel>
                </Border>

                <!-- ===== Content: split group OR single selected tab ===== -->
                <Grid>
                    <ItemsControl Visibility="{Binding CompareMode, Converter={StaticResource BoolToVis}}"
                                  ItemsSource="{Binding SplitGroup}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#0E0E0E" BorderThickness="1">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Background="#1B2B3F" Padding="6,3">
                                            <DockPanel>
                                                <CheckBox DockPanel.Dock="Right" Content="Sync" Foreground="#9CD"
                                                          VerticalAlignment="Center" IsChecked="{Binding IsSyncEnabled}"
                                                          ToolTip="Include this log when synchronizing the split view"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#ECECEC" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                        <views:LogTabView/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ContentControl Visibility="{Binding ShowSingleView, Converter={StaticResource BoolToVis}}"
                                    Content="{Binding SelectedTab}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:LogTabView/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- Shown when a workspace is open but no log tab yet -->
                    <TextBlock Visibility="{Binding ShowNoTabHint, Converter={StaticResource BoolToVis}}"
                               Text="Double-click a log in the workspace to open it."
                               Foreground="#777" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

            </DockPanel>
        </Grid>
        </Grid>
    </DockPanel>
</Window>
