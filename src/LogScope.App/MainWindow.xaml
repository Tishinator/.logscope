<Window x:Class="LogScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogScope.App.ViewModels"
        xmlns:views="clr-namespace:LogScope.App.Views"
        xmlns:conv="clr-namespace:LogScope.App.Converters"
        Title=".logscope" Height="700" Width="1150"
        Icon="Assets/app.ico"
        Background="#252526">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <HierarchicalDataTemplate DataType="{x:Type vm:WorkspaceNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="OnNodeClicked"
                        ToolTip="{Binding Tooltip}" Background="Transparent"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <TextBlock Text="📄" Visibility="{Binding IsFile, Converter={StaticResource BoolToVis}}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#DDD"/>
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open"
                                  Command="{Binding PlacementTarget.Tag.OpenInNewTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open in new tab"
                                  Command="{Binding PlacementTarget.Tag.OpenInNewTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Reveal in Explorer"
                                  Command="{Binding PlacementTarget.Tag.RevealInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open in default editor"
                                  Command="{Binding PlacementTarget.Tag.OpenInEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ===== Branded header bar ===== -->
        <Border DockPanel.Dock="Top" Padding="12,7">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1B2B3F" Offset="0"/>
                    <GradientStop Color="#22344C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <!-- Right-aligned menu -->
                <Menu DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center" Foreground="#DDD">
                    <MenuItem Header="_Open" Foreground="#1B2B3F">
                        <MenuItem Header="Open File…" Command="{Binding OpenFileCommand}"/>
                        <MenuItem Header="Open Folder…" Command="{Binding OpenFolderCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Profiles" Foreground="#1B2B3F">
                        <MenuItem Header="New parser profile… (for current file)" Command="{Binding NewProfileCommand}"/>
                        <MenuItem Header="Edit parser for current tab…" Command="{Binding EditParserCommand}"/>
                        <MenuItem Header="Import profile…" Command="{Binding ImportProfileCommand}"/>
                    </MenuItem>
                    <MenuItem Header="_Settings" Foreground="#1B2B3F">
                        <MenuItem Header="File extensions…" Command="{Binding EditExtensionsCommand}"/>
                        <MenuItem Header="Reset settings…" Command="{Binding ResetSettingsCommand}"/>
                    </MenuItem>
                </Menu>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo-mark.png" Height="32" Width="32" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="." Foreground="#2B8CE6" FontSize="21" FontWeight="Bold"/><Run Text="logscope" Foreground="#ECECEC" FontSize="21" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Border Background="#14B8A6" CornerRadius="3" Padding="5,1" Margin="12,2,0,0" VerticalAlignment="Center">
                        <TextBlock Text="read-only" Foreground="#0C2A26" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="offline log analysis" Foreground="#7C99B8" FontSize="11"
                               VerticalAlignment="Center" Margin="10,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
        <!-- ===== Landing screen (no workspace) ===== -->
        <Grid Visibility="{Binding HasWorkspace, Converter={StaticResource InverseBoolToVis}}"
              x:Name="LandingPanel">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="Assets/logo-full.png" Height="200" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,18"/>
                <TextBlock Text="Read-only log analysis for SDETs — offline and safe."
                           FontSize="14" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,28"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Open File…" Command="{Binding OpenFileCommand}"
                            Padding="20,10" Margin="0,0,12,0" FontSize="14"/>
                    <Button Content="Open Folder…" Command="{Binding OpenFolderCommand}"
                            Padding="20,10" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ===== Workspace view ===== -->
        <Grid Visibility="{Binding HasWorkspace, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: workspace tree -->
            <DockPanel Grid.Column="0" Background="#252526">
                <Border DockPanel.Dock="Top" Background="#333" Padding="8,6">
                    <DockPanel>
                        <TextBlock Text="WORKSPACE" Foreground="#999" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="File" Command="{Binding OpenFileCommand}" Padding="6,1" Margin="0,0,4,0" FontSize="11"/>
                            <Button Content="Folder" Command="{Binding OpenFolderCommand}" Padding="6,1" FontSize="11"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <TreeView x:Name="Tree" ItemsSource="{Binding WorkspaceRoots}"
                          Background="#252526" BorderThickness="0" Foreground="#DDD">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#1A1A1A"/>

            <!-- Right: open log tabs -->
            <TabControl Grid.Column="2" Background="#1E1E1E" BorderThickness="0"
                        ItemsSource="{Binding OpenTabs}" SelectedItem="{Binding SelectedTab}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            <Button Content="✕" Click="OnCloseTab" Tag="{Binding}" Margin="8,0,0,0"
                                    Padding="3,0" BorderThickness="0" Background="Transparent" Foreground="#999"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <views:LogTabView/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
        </Grid>
    </DockPanel>
</Window>
