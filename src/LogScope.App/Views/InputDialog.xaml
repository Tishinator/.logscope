<Window x:Class="LogScope.App.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="170" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#252526" ShowInTaskbar="False">
    <DockPanel Margin="14">
        <TextBlock x:Name="PromptText" DockPanel.Dock="Top" Foreground="#DDD" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Click="OnOk" Width="80" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Width="80"/>
        </StackPanel>
        <TextBox x:Name="ResponseBox" VerticalAlignment="Top" Padding="4" FontSize="13"/>
    </DockPanel>
</Window>
