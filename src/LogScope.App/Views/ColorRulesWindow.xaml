<Window x:Class="LogScope.App.Views.ColorRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:LogScope.App.Converters"
        Title="Color rules" Height="520" Width="820"
        WindowStartupLocation="CenterOwner" Background="#252526" ShowInTaskbar="False">
    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexToBrush"/>
    </Window.Resources>
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Rules apply top-to-bottom by priority (higher wins for the row colour). Match types: Field value (exact match on a field), Message contains (substring of Message), or Regex (matched against any field)."/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Click="OnOk" Width="90" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Width="90"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Margin="10,0,0,0" Width="120">
            <Button Content="Add" Click="OnAdd" Margin="0,0,0,6" Padding="0,4"/>
            <Button Content="Delete" Click="OnDelete" Margin="0,0,0,6" Padding="0,4"/>
            <Button Content="Move up" Click="OnMoveUp" Margin="0,0,0,6" Padding="0,4"/>
            <Button Content="Move down" Click="OnMoveDown" Margin="0,0,0,6" Padding="0,4"/>
            <Button Content="Restore defaults" Click="OnRestoreDefaults" Margin="0,12,0,0" Padding="0,4"/>
        </StackPanel>

        <DataGrid x:Name="Grid" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="#1E1E1E" Foreground="#DDD" RowBackground="#1E1E1E" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Match type" Width="150"
                                        SelectedItemBinding="{Binding Kind, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{x:Static vm:ColorRuleEditViewModel.Kinds}"
                                        xmlns:vm="clr-namespace:LogScope.App.ViewModels"/>
                <DataGridTextColumn Header="Field (optional)" Width="120"
                                    Binding="{Binding FieldName, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Value / pattern" Width="*"
                                    Binding="{Binding MatchValue, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Color (hex)" Width="110"
                                    Binding="{Binding Background, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTemplateColumn Header="Preview" Width="70" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Background, Converter={StaticResource HexToBrush}}"
                                    Height="18" Margin="4" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Priority" Width="70"
                                    Binding="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
