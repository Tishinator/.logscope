<UserControl x:Class="LogScope.App.Views.LogTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LogScope.App.Converters"
             DataContextChanged="OnDataContextChanged">
    <UserControl.Resources>
        <conv:HexColorToBrushConverter x:Key="HexToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="6">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="View:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <RadioButton x:Name="TableRadio" Content="Table" Foreground="#CCC" VerticalAlignment="Center"
                             GroupName="ViewMode" IsChecked="True" Margin="0,0,8,0"/>
                <RadioButton Content="Raw" Foreground="#CCC" VerticalAlignment="Center"
                             GroupName="ViewMode" IsChecked="{Binding IsRawView}" Margin="0,0,16,0"/>

                <TextBlock Text="Filter:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="160" VerticalAlignment="Center" Margin="0,0,4,0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Delay=250}"/>
                <CheckBox Content="regex" Foreground="#CCC" VerticalAlignment="Center"
                          IsChecked="{Binding FilterIsRegex}" Margin="0,0,8,0"/>
                <CheckBox Content="flagged only" Foreground="#CCC" VerticalAlignment="Center"
                          IsChecked="{Binding OnlyFlagged}" Margin="0,0,16,0"/>

                <TextBlock Text="Search:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="140" VerticalAlignment="Center" Margin="0,0,4,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Content="Aa" Foreground="#CCC" VerticalAlignment="Center" ToolTip="Case sensitive"
                          IsChecked="{Binding SearchCaseSensitive}" Margin="0,0,4,0"/>
                <CheckBox Content=".*" Foreground="#CCC" VerticalAlignment="Center" ToolTip="Regex"
                          IsChecked="{Binding SearchIsRegex}" Margin="0,0,4,0"/>
                <Button Content="◀" Command="{Binding FindPrevCommand}" Margin="0,0,2,0" Padding="6,2" ToolTip="Previous match"/>
                <Button Content="▶" Command="{Binding FindNextCommand}" Margin="0,0,16,0" Padding="6,2" ToolTip="Next match"/>

                <CheckBox Content="Stream" Foreground="#7CD" VerticalAlignment="Center"
                          IsChecked="{Binding StreamingEnabled}" ToolTip="Follow appended content" Margin="0,0,16,0"/>

                <Button Content="Restore order" Command="{Binding RestoreOrderCommand}" Padding="6,2" Margin="0,0,6,0"
                        ToolTip="Restore original file order (UR-09)"/>
                <Button Content="Copy ▾" Padding="6,2" Margin="0,0,6,0" Click="OnCopyMenu"
                        ToolTip="Copy selected (or all visible) rows">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy rows (TSV)" Command="{Binding CopyRowsCommand}"/>
                            <MenuItem Header="Copy raw text" Command="{Binding CopyRawCommand}"/>
                            <MenuItem Header="Copy line references" Command="{Binding CopyLineRefsCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Menu Background="Transparent" VerticalAlignment="Center" Margin="0,0,6,0">
                    <MenuItem Header="Presets ▾" Foreground="#CCC">
                        <MenuItem Header="Save current filter…"
                                  Command="{Binding DataContext.SaveFilterPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Separator/>
                        <MenuItem Header="Apply"
                                  ItemsSource="{Binding DataContext.FilterPresets, RelativeSource={RelativeSource AncestorType=Window}}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Name}"/>
                                    <Setter Property="Command" Value="{Binding DataContext.ApplyFilterPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Menu Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="Encoding ▾" Foreground="#CCC">
                        <MenuItem Header="UTF-8" Command="{Binding DataContext.ReloadEncodingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="UTF-8"/>
                        <MenuItem Header="UTF-16 LE" Command="{Binding DataContext.ReloadEncodingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="UTF-16 LE"/>
                        <MenuItem Header="UTF-16 BE" Command="{Binding DataContext.ReloadEncodingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="UTF-16 BE"/>
                        <MenuItem Header="Windows-1252 (ANSI)" Command="{Binding DataContext.ReloadEncodingCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Windows-1252 (ANSI)"/>
                    </MenuItem>
                </Menu>
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="6,3">
            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11"/>
        </Border>

        <Grid>
            <!-- Table view -->
            <DataGrid x:Name="Grid"
                      Visibility="{Binding IsTableView, Converter={StaticResource BoolToVis}}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      ItemsSource="{Binding Rows}"
                      SelectionMode="Extended"
                      SelectionChanged="OnSelectionChanged"
                      Sorting="OnSorting"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="#1E1E1E" Foreground="#DDD"
                      BorderThickness="0" FontFamily="Consolas"
                      RowDetailsVisibilityMode="VisibleWhenSelected">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy rows (TSV)" Command="{Binding CopyRowsCommand}"/>
                        <MenuItem Header="Copy raw text" Command="{Binding CopyRawCommand}"/>
                        <MenuItem Header="Copy line references" Command="{Binding CopyLineRefsCommand}"/>
                        <Separator/>
                        <MenuItem Header="Restore original order" Command="{Binding RestoreOrderCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#3C4A5E"/>
                        <Setter Property="Foreground" Value="#F2F4F7"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Padding" Value="9,6"/>
                        <Setter Property="BorderBrush" Value="#22303F"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding RowBackground, Converter={StaticResource HexToBrush}}"/>
                    </Style>
                </DataGrid.RowStyle>
                <!-- Transparent cells so the row tint (color rules) shows through -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#DDD"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#264F78"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ContinuationText}" Foreground="#9CDCFE"
                                   FontFamily="Consolas" TextWrapping="Wrap" Margin="40,2,8,4"
                                   Visibility="{Binding HasContinuation, Converter={StaticResource BoolToVis}}"/>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>

            <!-- Raw view -->
            <TextBox x:Name="RawBox"
                     Visibility="{Binding IsRawView, Converter={StaticResource BoolToVis}}"
                     Text="{Binding RawText, Mode=OneWay}"
                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     FontFamily="Consolas" Background="#1E1E1E" Foreground="#DDD"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" BorderThickness="0"/>
        </Grid>
    </DockPanel>
</UserControl>
